{
  "name": "@hocgin/tts-cli",
  "version": "1.0.0",
  "description": "TTS CLI tool powered by Edge TTS",
  "type": "module",
  "bin": {
    "tts": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "prettier --check src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "tts",
    "text-to-speech",
    "edge-tts",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "commander": "^14.0.3",
    "edge-tts-universal": "^1.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
